# ─────────────────────────────────────────────
# Required
# ─────────────────────────────────────────────

# Groq API key — get one free at https://console.groq.com
# Leave empty (or omit) to run without AI features
GROQ_API_KEY=

# NewsAPI key — get one free at https://newsapi.org
NEWS_API_KEY=

# ─────────────────────────────────────────────
# Optional
# ─────────────────────────────────────────────

# Set to "false" to disable AI features even if GROQ_API_KEY is set
# AI_ENABLED=true
